# Faro collector URL from Grafana Cloud → Observability → Frontend → pizza-frontend
# → Configuration. Safe to bake into the browser bundle (the app key isn't a secret).
VITE_FARO_URL=https://faro-collector-prod-eu-west-2.grafana.net/collect/<app-key>

# Where the frontend sends /api/* calls. Leave unset for local dev (Vite proxy
# handles it); set to /pizza/api for the production GitHub Pages build so the
# main-site Vercel rewrite resolves it same-origin.
VITE_API_BASE_URL=/pizza/api
